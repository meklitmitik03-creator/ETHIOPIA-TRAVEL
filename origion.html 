<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"> 
    <meta name="theme-color" content="#2e7d32">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <link rel="manifest" href="manifest.json">
    <title>Land of Origins - Ethiopia AI</title>
    <link rel="stylesheet" href="style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .panel {
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
            background-size: cover;
            background-position: center;
            scroll-snap-align: start;
        }

        .video-bg {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            z-index: -1;
        }

        .video-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.4);
            z-index: 0;
        }

        .glass-card { z-index: 1; }
        #sidebar { z-index: 1001; }
        .toggle-btn { z-index: 1002; cursor: pointer; }
    </style>
</head>

<div id="splash-screen" style="position:fixed; top:0; left:0; width:100%; height:100%; background:#3e2723; display:flex; justify-content:center; align-items:center; z-index:9999; transition: opacity 0.5s;">
    <div style="text-align:center; color:white;">
        <h1 style="margin:0;">☕</h1>
        <p>Land of Origins</p>
    </div>
</div>

<body>

    <nav class="sidebar" id="sidebar">
        <div class="toggle-btn" onclick="toggleSidebar()">
            <i class="fas fa-bars"></i>
        </div>
        <ul class="nav-links">
            <li><a href="index.html"><i class="fas fa-home"></i><span class="link-text">Home</span></a></li>
            <li><a href="origin.html" class="active"><i class="fas fa-seedling"></i><span class="link-text">Origins</span></a></li>
            <li><a href="history.html"><i class="fas fa-monument"></i><span class="link-text">History</span></a></li>
            <li><a href="culture.html"><i class="fas fa-users"></i><span class="link-text">Culture</span></a></li>
        </ul>
    </nav>

    <main class="scroll-container" id="mainScroll">
        
        <section class="panel">
            <video autoplay muted loop playsinline class="video-bg">
                <source src="https://player.vimeo.com/external/403635744.sd.mp4?s=6e3e54b670355f6574f26a100529d2f2d93e5062&profile_id=164&oauth2_token_id=57447761" type="video/mp4">
            </video>
            <div class="video-overlay"></div>
            <div class="glass-card">
                <i class="fas fa-mug-hot card-icon" style="color: #ffca28;"></i>
                <h2>Origin of Coffee</h2>
                <p>Follow the legend of Kaldi and his dancing goats in the ancient forests of Kaffa.</p>
                <button class="explore-btn">Coffee Ceremony</button>
            </div>
        </section>

        <section class="panel" style="background-image: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('https://images.unsplash.com/photo-1510936111840-65e151ad71bb?auto=format&fit=crop&q=80');">
            <div class="glass-card">
                <i class="fas fa-dna card-icon" style="color: #4db6ac;"></i>
                <h2>Origin of Life</h2>
                <p>Meet "Dinknesh" (Lucy), our 3.2 million-year-old ancestor found in the Afar region.</p>
                <button class="explore-btn">Meet Lucy</button>
            </div>
        </section>

    </main>

    <div class="ai-chat-wrapper">
        <div class="chat-toggle" onclick="toggleChat()">
            <i class="fa-solid fa-robot"></i>
        </div>
        <div class="chat-window" id="chatWindow">
            <div class="chat-header">
                <span>Origins AI Guide</span>
                <i class="fa-solid fa-circle-info"></i>
            </div>
            <div class="chat-content" id="chatContent">
                <div class="ai-msg">Ameseginalehu! Ask me about the history of coffee or human evolution in Ethiopia.</div>
            </div>
            <div class="chat-input-area">
                <input type="text" id="userInput" placeholder="Ask about coffee or Lucy..." onkeypress="handleKeyPress(event)">
                <button onclick="sendMessage()"><i class="fa-solid fa-paper-plane"></i></button>
            </div>
        </div>
    </div>

    <script>
        // Splash logic
        window.addEventListener('load', () => {
            setTimeout(() => {
                const splash = document.getElementById('splash-screen');
                splash.style.opacity = '0';
                setTimeout(() => splash.remove(), 500);
            }, 1500);
        });

        // Chat Logic
        async function sendMessage() {
            const input = document.getElementById('userInput');
            const chatContent = document.getElementById('chatContent');
            const message = input.value.trim();
            if (!message) return;

            chatContent.innerHTML += `<div class="user-msg" style="text-align:right; margin:10px; color:#2e7d32; font-weight:bold;">You: ${message}</div>`;
            input.value = '';

            const loadingDiv = document.createElement("div");
            loadingDiv.className = "ai-msg";
            loadingDiv.innerText = "AI is thinking... ⏳";
            chatContent.appendChild(loadingDiv);
            chatContent.scrollTop = chatContent.scrollHeight;

            try {
                const response = await fetch('https://shiny-dollop-x5gxg6gw49g43645p-3000.app.github.dev/chat', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ message: message })
                });
                const data = await response.json();
                loadingDiv.innerText = data.reply || data.error;
            } catch (error) {
                loadingDiv.innerText = "Error: Server offline.";
            }
            chatContent.scrollTop = chatContent.scrollHeight;
        }

        function handleKeyPress(event) { if (event.key === "Enter") sendMessage(); }
        function toggleSidebar() { document.getElementById('sidebar').classList.toggle('collapsed'); }
        function toggleChat() { document.getElementById('chatWindow').classList.toggle('active'); }

        // Auto Scroll (1 Minute)
        const scrollDiv = document.getElementById('mainScroll');
        let currentPos = 0;
        setInterval(() => {
            currentPos = (currentPos + window.innerHeight >= scrollDiv.scrollHeight) ? 0 : currentPos + window.innerHeight;
            scrollDiv.scrollTo({ top: currentPos, behavior: 'smooth' });
        }, 60000);
    </script>
</body>
</html>